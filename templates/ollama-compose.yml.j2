---

services:
  ollama:
    container_name: {{ ollama_container_name }}
    hostname: {{ ollama_container_name }}
    image: {{ ollama_image | default('ollama/ollama:latest') }}
    ports:
      - "{{ ollama_host_port | default(11434) }}:11434"  # Ollama API port
    networks:
      - homelab-bridge
    dns:
      - {{ monolith_ip }}  # Host IP where Pi-hole DNS binds on port 53
      - 1.1.1.1  # Cloudflare DNS for reliable external resolution
      - 8.8.8.8  # Google DNS fallback
    dns_search:
      - local  # Optional: for local domain resolution
    volumes:
      - type: bind
        source: /opt/ollama/data
        target: /root/.ollama
        read_only: false
{% for storage_mount in shared_storage_mounts | default([]) %}
      - type: bind
        source: {{ storage_mount.source }}
        target: {{ storage_mount.target }}
        read_only: {{ 'true' if storage_mount.read_only | default(false) else 'false' }}
{% endfor %}
    environment:
      TZ: {{ timezone | default('America/Los_Angeles') }}
    deploy:
      replicas: 1
      resources:
        limits:
          memory: 8G
        reservations:
          memory: 2G
{% if ollama_gpu_enabled | default(false) %}
          devices:
            - driver: nvidia
              count: {{ ollama_gpu_device_count | default(1) }}
              capabilities: {{ ollama_gpu_capabilities | default(['gpu']) }}
{% endif %}
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
        window: 120s
      update_config:
        order: start-first
        failure_action: rollback

networks:
  homelab-bridge:
    name: homelab-bridge
    external: true

---

services:
  open-webui:
    container_name: {{ open_webui_container_name }}
    hostname: {{ open_webui_container_name }}
    image: {{ open_webui_image | default('ghcr.io/open-webui/open-webui:main') }}
    ports:
      - "{{ open_webui_host_port | default(8080) }}:8080"  # Open WebUI web interface
    networks:
      - homelab-bridge
    dns:
      - {{ monolith_ip }}  # Host IP where Pi-hole DNS binds on port 53
      - 1.1.1.1  # Cloudflare DNS for reliable external resolution
      - 8.8.8.8  # Google DNS fallback
    dns_search:
      - local  # Optional: for local domain resolution
    volumes:
      - type: bind
        source: /opt/open-webui/data
        target: /app/backend/data
        read_only: false
{% for storage_mount in shared_storage_mounts | default([]) %}
      - type: bind
        source: {{ storage_mount.source }}
        target: {{ storage_mount.target }}
        read_only: {{ 'true' if storage_mount.read_only | default(false) else 'false' }}
{% endfor %}
    environment:
      TZ: {{ timezone | default('America/Los_Angeles') }}
      # Ollama backend configuration
      OLLAMA_BASE_URL: "http://{{ ollama_container_name }}:{{ ollama_internal_port | default(11434) }}"
      # Optional: Set default model (update after deployment)
      WEBUI_DEFAULT_MODELS: "{{ open_webui_default_models | default('') }}"
    deploy:
      replicas: 1
      resources:
        limits:
          memory: 4G
        reservations:
          memory: 1G
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
        window: 120s
      update_config:
        order: start-first
        failure_action: rollback

networks:
  homelab-bridge:
    name: homelab-bridge
    external: true

---
version: "3.8"

services:
  portainer:
    container_name: {{ portainer_container_name }}
    image: portainer/portainer-ce:lts
    hostname: {{ portainer_container_name }}
    ports:
      - "8000:8000"
      - "9000:9000"
      - "{{ portainer_host_port }}:9443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data
{% for storage_mount in shared_storage_mounts | default([]) %}
      - type: bind
        source: {{ storage_mount.source }}
        target: {{ storage_mount.target }}
        read_only: {{ 'true' if storage_mount.read_only | default(false) else 'false' }}
{% endfor %}
    environment:
      - AGENT_SECRET={{ portainer_agent_secret }}
    networks:
      - homelab-bridge
    restart: unless-stopped

volumes:
  portainer_data:

networks:
  homelab-bridge:
    name: homelab-bridge
    external: true

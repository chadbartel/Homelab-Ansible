---
# Headscale - Self-hosted Tailscale control plane
# Runs on bridge network; NPM proxies via container name
# Reference: https://github.com/juanfont/headscale

version: '3.9'

services:
  headscale:
    image: "{{ headscale_image | default('ghcr.io/juanfont/headscale:latest') }}"
    container_name: "{{ headscale_container_name }}"
    hostname: "{{ headscale_container_name }}"
    ports:
      - "{{ headscale_host_port | default(8080) }}:{{ headscale_container_port | default(8080) }}/tcp"
      - "50443:50443/udp"  # DERP server port (UDP, required for relay)
    environment:
      TZ: "{{ timezone }}"
    volumes:
      - headscale_config:/etc/headscale
      - headscale_data:/var/lib/headscale
    cap_add:
      - NET_ADMIN
    networks:
      - homelab-bridge
    restart: unless-stopped

networks:
  homelab-bridge:
    external: true

volumes:
  headscale_config:
  headscale_data:
